			<chSubstda>{@chSubstda}</chSubstda>
			<cMotivo>{@cMotivo}</cMotivo>
			{@ifXMotivo}
			<xMotivo>{@xMotivo}</xMotivo>
			{@endifXMotivo}
		</subst>
		{@endifSubst}
		<prest>
			<!-- IF CHOICE CNPJ/CPF/NIF/C NÃO NIF TOMADOR -->
			{@ifCNPJPrestador}
			<CNPJ>{@CNPJPrestador}</CNPJ>
			{@endifCNPJPrestador}
			{@ifCPFPrestador}
			<CPF>{@CPFPrestador}</CPF>
			{@endifCPFPrestador}
			{@ifNIFPrestador}
			<NIF>{@NIFPrestador}</NIF>
			{@endifNIFPrestador}
			{@ifCNaoNIFPrestador}
			<cNaoNIF>{@cNaoNIFPrestador}</cNaoNIF>
			{@endifCNaoNIFPrestador}
			<!-- IF OPCIONAL CAEPF DPS PRESTADOR -->
			{@ifCAEPFPrestador}
			<CAEPF>{@CAEPFPrestador}</CAEPF>
			{@endifCAEPFPrestador}
			{@ifIMPrestador}
			<IM>{@IMPrestador}</IM>
			{@endifIMPrestador}
			<!-- {@ifXNomePrestador}
			<xNome>{@xNomePrestador}</xNome>
			{@endifXNomePrestador} -->
			<!-- IF OPCIONAL END DPS PRESTADOR -->
			<!-- {@ifEndPrestador}
			<end>
				{@ifEndNacPrestador}
				<endNac>
					<cMun>{@cMunPrestador}</cMun>
					<CEP>{@CEPPrestador}</CEP>
				</endNac>
				{@endifEndNacPrestador}
				{@ifEndExtPrestador}
				<endExt>
					<cPais>{@cPaisPrestador}</cPais>
					<cEndPost>{@cEndPostPrestador}</cEndPost>
					<xCidade>{@xCidadePrestador}</xCidade>
					<xEstProvReg>{@xEstProvRegPrestador}</xEstProvReg>
				</endExt>
				{@endifEndExtPrestador}
				<xLgr>{@xLgrPrestador}</xLgr>
				<nro>{@nroPrestador}</nro>
				{@ifXCplPrestador}
				<xCpl>{@xCplPrestador}</xCpl>
				{@endifXCplPrestador}
				<xBairro>{@xBairroPrestador}</xBairro>
			</end>
			{@endifEndPrestador} -->
			{@ifFonePrestador}
			<fone>{@fonePrestador}</fone>
			{@endifFonePrestador}
			{@ifEmailPrestador}
			<email>{@emailPrestador}</email>
			{@endifEmailPrestador}
			<regTrib>
				<opSimpNac>{@opSimpNac}</opSimpNac>
				{@ifRegApTribSN}
				<regApTribSN>{@regApTribSN}</regApTribSN>
				{@endifRegApTribSN}
				<regEspTrib>{@regEspTrib}</regEspTrib>
			</regTrib>
		</prest>
		{@ifToma}
		<toma>
			<!-- IF CHOICE CNPJ/CPF/NIF/C NÃO NIF TOMADOR -->
			{@ifCNPJTomador}
			<CNPJ>{@CNPJTomador}</CNPJ>
			{@endifCNPJTomador}
			{@ifCPFTomador}
			<CPF>{@CPFTomador}</CPF>
			{@endifCPFTomador}
			{@ifNIFTomador}
			<NIF>{@NIFTomador}</NIF>
			{@endifNIFTomador}
			{@ifCNaoNIFTomador}
			<cNaoNIF>{@cNaoNIFTomador}</cNaoNIF>
			{@endifCNaoNIFTomador}
			<!-- IF OPCIONAL CAEPF DPS TOMADOR -->
			{@ifCAEPFTomador}
			<CAEPF>{@CAEPFTomador}</CAEPF>
			{@endifCAEPFTomador}
			<!-- IF OPCIONAL IM DPS TOMADOR -->
			{@ifIMTomador}
			<IM>{@IMTomador}</IM>
			{@endifIMTomador}
			<xNome>{@xNomeTomador}</xNome>
			<!-- IF OPCIONAL END DPS TOMADOR -->
			{@ifEndTomador}
			<end>
				{@ifEndNacTomador}
				<endNac>
					<cMun>{@cMunTomador}</cMun>
					<CEP>{@CEPTomador}</CEP>
				</endNac>
				{@endifEndNacTomador}
				{@ifEndExtTomador}
				<endExt>
					<cPais>{@cPaisTomador}</cPais>
					<cEndPost>{@cEndPostTomador}</cEndPost>
					<xCidade>{@xCidadeTomador}</xCidade>
					<xEstProvReg>{@xEstProvRegTomador}</xEstProvReg>
				</endExt>
				{@endifEndExtTomador}
				<xLgr>{@xLgrTomador}</xLgr>
				<nro>{@nroTomador}</nro>
				{@ifXCplTomador}
				<xCpl>{@xCplTomador}</xCpl>
				{@endifXCplTomador}
				<xBairro>{@xBairroTomador}</xBairro>
			</end>
			{@endifEndTomador}
			{@ifFoneTomador}
			<fone>{@foneTomador}</fone>
			{@endifFoneTomador}
			{@ifEmailTomador}
			<email>{@emailTomador}</email>
			{@endifEmailTomador}
		</toma>
		{@endifToma}
		{@ifInterm}
		<interm>
			<!-- IF CHOICE CNPJ/CPF/NIF/C NÃO NIF INTERMEDIÁRIO -->
			{@ifCNPJInterm}
			<CNPJ>{@CNPJInterm}</CNPJ>
			{@endifCNPJInterm}
			{@ifCPFInterm}
			<CPF>{@CPFInterm}</CPF>
			{@endifCPFInterm}
			{@ifNIFInterm}
			<NIF>{@NIFInterm}</NIF>
			{@endifNIFInterm}
			{@ifCNaoNIFInterm}
			<cNaoNIF>{@cNaoNIFInterm}</cNaoNIF>
			{@endifCNaoNIFInterm}
			<!-- IF OPCIONAL CAEPF INTERMEDIÁRIO -->
			{@ifCAEPFInterm}
			<CAEPF>{@CAEPFInterm}</CAEPF>
			{@endifCAEPFInterm}
			<!-- IF OPCIONAL IM INTERMEDIÁRIO -->
			{@ifIMInterm}
			<IM>{@IMInterm}</IM>
			{@endifIMInterm}
			<xNome>{@xNomeInterm}</xNome>
			<!-- IF OPCIONAL END INTERMEDIÁRIO -->
			{@ifEndInterm}
			<end>
				{@ifEndNacInterm}
				<endNac>
					<cMun>{@cMunInterm}</cMun>
					<CEP>{@CEPInterm}</CEP>
				</endNac>
				{@endifEndNacInterm}
				{@ifEndExtInterm}
				<endExt>
					<cPais>{@cPaisInterm}</cPais>
					<cEndPost>{@cEndPostInterm}</cEndPost>
					<xCidade>{@xCidadeInterm}</xCidade>
					<xEstProvReg>{@xEstProvRegInterm}</xEstProvReg>
				</endExt>
				{@endifEndExtInterm}
				<xLgr>{@xLgrInterm}</xLgr>
				<nro>{@nroInterm}</nro>
				{@ifXCplInterm}
				<xCpl>{@xCplInterm}</xCpl>
				{@endifXCplInterm}
				<xBairro>{@xBairroInterm}</xBairro>
			</end>
			{@endifEndInterm}
			{@ifFoneInterm}
			<fone>{@foneInterm}</fone>
			{@endifFoneInterm}
			{@ifEmailInterm}
			<email>{@emailInterm}</email>
			{@endifEmailInterm}
		</interm>
		{@endifInterm}
		<serv>
			<locPrest>
				{@ifCLocPrestacao}
				<cLocPrestacao>{@cLocPrestacao}</cLocPrestacao>
				{@endifCLocPrestacao}
				{@ifCPaisPrestacao}
				<cPaisPrestacao>{@cPaisPrestacao}</cPaisPrestacao>
				{@endifCPaisPrestacao}
			</locPrest>
			<cServ>
				<cTribNac>{@cTribNac}</cTribNac>
				{@ifCTribMun}
				<cTribMun>{@cTribMun}</cTribMun>
				{@endifCTribMun}
				<xDescServ>{@xDescServ}</xDescServ>
				{@ifCNBS}
				<cNBS>{@cNBS}</cNBS>
				{@endifCNBS}
				{@ifCIntContrib}
				<cIntContrib>{@cIntContrib}</cIntContrib>
				{@endifCIntContrib}
			</cServ>
			{@ifComExt}
			<comExt>
				<mdPrestacao>{@mdPrestacao}</mdPrestacao>
				<vincPrest>{@vincPrest}</vincPrest>
				<tpMoeda>{@tpMoeda}</tpMoeda>
				<vServMoeda>{@vServMoeda}</vServMoeda>
				<mecAFComexP>{@mecAFComexP}</mecAFComexP>
				<mecAFComexT>{@mecAFComexT}</mecAFComexT>
				<movTempBens>{@movTempBens}</movTempBens>
				{@ifNDI}
				<nDI>{@nDI}</nDI>
				{@endifNDI}
				{@ifNRE}
				<nRE>{@nRE}</nRE>
				{@endifNRE}
				<mdic>{@mdic}</mdic>
			</comExt>
			{@endifComExt}
			{@ifObra}
			<obra>
				{@ifInscImobFiscObra}
				<inscImobFisc>{@inscImobFiscObra}</inscImobFisc>
				{@endifInscImobFiscObra}
				{@ifCObra}
				<cObra>{@cObra}</cObra>
				{@endifCObra}
				{@ifCCIBObra}
				<cCIB>{@cCIBObra}</cCIB>
				{@endifCCIBObra}
				{@ifEndObra}
				<end>
					{@ifCEPObra}
					<CEP>{@CEPObra}</CEP>
					{@endifCEPObra}
					{@ifEndExtObra}
					<endExt>
						<cEndPost>{@cEndPostObra}</cEndPost>
						<xCidade>{@xCidadeObra}</xCidade>
						<xEstProvReg>{@xEstProvRegObra}</xEstProvReg>
					</endExt>
					{@endifEndExtObra}
					<xLgr>{@xLgrObra}</xLgr>
					<nro>{@nroObra}</nro>
					{@ifXCplObra}
					<xCpl>{@xCplObra}</xCpl>
					{@endifXCplObra}
					<xBairro>{@xBairroObra}</xBairro>
				</end>
				{@endifEndObra}
			</obra>
			{@endifObra}
			{@ifAtvEvento}
			<atvEvento>
				<desc>{@xNomeAtvEvento}</desc>
				<dtIni>{@dtIniAtvEvento}</dtIni>
				<dtFim>{@dtFimAtvEvento}</dtFim>
				{@ifIdAtvEv}
				<id>{@idAtvEv}</id>
				{@endifIdAtvEv}
				{@ifEndAtvEv}
				<end>
					{@ifCEPAtvEvento}
					<CEP>{@CEPAtvEvento}</CEP>
					{@endifCEPAtvEvento}
					{@ifEndExtAtvEvento}
					<endExt>
						<cEndPost>{@cEndPostAtvEvento}</cEndPost>
						<xCidade>{@xCidadeAtvEvento}</xCidade>
						<xEstProvReg>{@xEstProvRegAtvEvento}</xEstProvReg>
					</endExt>
					{@endifEndExtAtvEvento}
					<xLgr>{@xLgrAtvEvento}</xLgr>
					<nro>{@nroAtvEvento}</nro>
					{@ifXCplAtvEvento}
					<xCpl>{@xCplAtvEvento}</xCpl>
					{@endifXCplAtvEvento}
					<xBairro>{@xBairroAtvEvento}</xBairro>
				</end>
				{@endifEndAtvEv}
			</atvEvento>
			{@endifAtvEvento}
			{@ifInfoCompl}
			<infoCompl>
				{@ifIdDocTec}
				<idDocTec>{@idDocTec}</idDocTec>
				{@endifIdDocTec}
				{@ifDocRef}
				<docRef>{@docRef}</docRef>
				{@endifDocRef}
				{@ifXInfComp}
				<xInfComp>{@xInfComp}</xInfComp>
				{@endifXInfComp}
			</infoCompl>
			{@endifInfoCompl}
		</serv>
		<valores>
			<vServPrest>
				{@ifVReceb}
				<vReceb>{@vReceb}</vReceb>
				{@endifVReceb}
				<vServ>{@vServ}</vServ>
			</vServPrest>
			{@ifVDescCondIncond}
			<vDescCondIncond>
				{@ifVDescIncond}
				<vDescIncond>{@vDescIncond}</vDescIncond>
				{@endifVDescIncond}
				{@ifVDescCond}
				<vDescCond>{@vDescCond}</vDescCond>
				{@endifVDescCond}
			</vDescCondIncond>
			{@endifVDescCondIncond}
			{@ifVDedRed}
			<vDedRed>
				{@ifPDR}
				<pDR>{@pDR}</pDR>
				{@endifPDR}
				{@ifVDR}
				<vDR>{@vDR}</vDR>
				{@endifVDR}
				{@ifDocumentos}
				<documentos>
					<docDedRed>
						{@ifChNFSe}
						<chNFSe>{@chNFSe}</chNFSe>
						{@endifChNFSe}
						{@ifChNFe}
						<chNFe>{@chNFe}</chNFe>
						{@endifChNFe}
						{@ifNFSeMun}
						<NFSeMun>
							<cMunNFSeMun>{@cMunNFSeMun}</cMunNFSeMun>
							<nNFSeMun>{@nNFSeMun}</nNFSeMun>
							<cVerifNFSeMun>{@cVerifNFSeMun}</cVerifNFSeMun>
						</NFSeMun>
						{@endifNFSeMun}
						{@ifNFNFS}
						<NFNFS>
							<nNFNFS>{@nNFNFS}</nNFNFS>
							<modNFNFS>{@modNFNFS}</modNFNFS>
							<serieNFNFS>{@serieNFNFS}</serieNFNFS>
						</NFNFS>
						{@endifNFNFS}
						{@ifNDocFisc}
						<nDocFisc>{@nDocFisc}</nDocFisc>
						{@endifNDocFisc}
						{@ifNDoc}
						<nDoc>{@nDoc}</nDoc>
						{@endifNDoc}
						<tpDedRed>{@tpDedRed}</tpDedRed>
						{@ifXDescOutDed}
						<xDescOutDed>{@xDescOutDed}</xDescOutDed>
						{@endifXDescOutDed}
						<dtEmiDoc>{@dtEmiDoc}</dtEmiDoc>
						<vDedutivelRedutivel>{@vDedutivelRedutivel}</vDedutivelRedutivel>
						<vDeducaoReducao>{@vDeducaoReducao}</vDeducaoReducao>
						{@ifFornec}
						<fornec>
							{@ifCNPJFornec}
							<CNPJ>{@CNPJFornec}</CNPJ>
							{@endifCNPJFornec}
							{@ifCPFFornec}
							<CPF>{@CPFFornec}</CPF>
							{@endifCPFFornec}
							{@ifNIFFornec}
							<NIF>{@NIFFornec}</NIF>
							{@endifNIFFornec}
							{@ifCNaoNIFFornec}
							<cNaoNIF>{@cNaoNIFFornec}</cNaoNIF>
							{@endifCNaoNIFFornec}
							{@ifCAEPFFornec}
							<CAEPF>{@CAEPFFornec}</CAEPF>
							{@endifCAEPFFornec}
							{@ifIMFornec}
							<IM>{@IMFornec}</IM>
							{@endifIMFornec}
							<xNome>{@xNomeFornec}</xNome>
							{@ifEndFornec}
							<end>
								{@ifEndNacFornec}
								<endNac>
									<cMun>{@cMunFornec}</cMun>
									<CEP>{@CEPFornec}</CEP>
								</endNac>
								{@endifEndNacFornec}
								{@ifEndExtFornec}
								<endExt>
									<cPais>{@cPaisFornec}</cPais>
									<cEndPost>{@cEndPostFornec}</cEndPost>
									<xCidade>{@xCidadeFornec}</xCidade>
									<xEstProvReg>{@xEstProvRegFornec}</xEstProvReg>
								</endExt>
								{@endifEndExtFornec}
								<xLgr>{@xLgrFornec}</xLgr>
								<nro>{@nroFornec}</nro>
								{@ifXCplFornec}
								<xCpl>{@xCplFornec}</xCpl>
								{@endifXCplFornec}
								<xBairro>{@xBairroFornec}</xBairro>
							</end>
							{@endifEndFornec}
							{@ifFoneFornec}
							<fone>{@foneFornec}</fone>
							{@endifFoneFornec}
							{@ifEmailFornec}
							<email>{@emailFornec}</email>
							{@endifEmailFornec}
						</fornec>
						{@endifFornec}
					</docDedRed>
				</documentos>
				{@endifDocumentos}
			</vDedRed>
			{@endifVDedRed}
			<trib>
				<tribMun>
					<tribISSQN>{@tribISSQN}</tribISSQN>
					{@ifCPaisResult}
					<cPaisResult>{@cPaisResult}</cPaisResult>
					{@endifCPaisResult}
					{@ifBM}
					<BM>
						<nBM>{@nBM}</nBM>
						{@ifVRedBCBM}
						<vRedBCBM>{@vRedBCBM}</vRedBCBM>
						{@endifVRedBCBM}
						{@ifPRedBCBM}
						<pRedBCBM>{@pRedBCBM}</pRedBCBM>
						{@endifPRedBCBM}
					</BM>
					{@endifBM}
					{@ifExigSusp}
					<exigSusp>
						<tpSusp>{@tpSusp}</tpSusp>
						<nProcesso>{@nProcesso}</nProcesso>
					</exigSusp>
					{@endifExigSusp}
					{@ifTpImunidade}
					<tpImunidade>{@tpImunidade}</tpImunidade>
					{@endifTpImunidade}
					<!-- {@ifPAliqISSQN}
					<pAliq>{@pAliq}</pAliq>
					{@endifPAliqISSQN} -->
					<tpRetISSQN>{@tpRetISSQN}</tpRetISSQN>
				</tribMun>
				{@ifTribFed}
				<tribNac>
					{@ifPiscofins}
					<piscofins>
						<CST>{@CST}</CST>
						{@ifVBCPisCofins}
						<vBCPisCofins>{@vBCPisCofins}</vBCPisCofins>
						{@endifVBCPisCofins}
						{@ifPAliqPis}
						<pAliqPis>{@pAliqPis}</pAliqPis>
						{@endifPAliqPis}
						{@ifPAliqCofins}
						<pAliqCofins>{@pAliqCofins}</pAliqCofins>
						{@endifPAliqCofins}
						{@ifVPis}
						<vPis>{@vPis}</vPis>
						{@endifVPis}
						{@ifVCofins}
						<vCofins>{@vCofins}</vCofins>
						{@endifVCofins}
						{@ifTpRetPisCofins}
						<tpRetPisCofins>{@tpRetPisCofins}</tpRetPisCofins>
						{@endifTpRetPisCofins}
					</piscofins>
					{@endifPiscofins}
					{@ifVRetCP}
					<vRetCP>{@vRetCP}</vRetCP>
					{@endifVRetCP}
					{@ifVRetIRRF}
					<vRetIRRF>{@vRetIRRF}</vRetIRRF>
					{@endifVRetIRRF}
					{@ifVRetCSLL}
					<vRetCSLL>{@vRetCSLL}</vRetCSLL>
					{@endifVRetCSLL}
				</tribNac>
				{@endifTribFed}
				<totTrib>
					{@ifVTotTrib}
					<vTotTrib>
						<vTotTribFed>{@vTotTribFed}</vTotTribFed>
						<vTotTribEst>{@vTotTribEst}</vTotTribEst>
						<vTotTribMun>{@vTotTribMun}</vTotTribMun>
					</vTotTrib>
					{@endifVTotTrib}
					{@ifPTotTrib}
					<pTotTrib>
						<pTotTribFed>{@pTotTribFed}</pTotTribFed>
						<pTotTribEst>{@pTotTribEst}</pTotTribEst>
						<pTotTribMun>{@pTotTribMun}</pTotTribMun>
					</pTotTrib>
					{@endifPTotTrib}
					{@ifIndTotTrib}
					<indTotTrib>{@indTotTrib}</indTotTrib>
					{@endifIndTotTrib}
					{@ifPTotTribSN}
					<pTotTribSN>{@pTotTribSN}</pTotTribSN>
					{@endifPTotTribSN}
				</totTrib>
			</trib>
		</valores>
	</infDPS>
