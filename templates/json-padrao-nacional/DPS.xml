<?xml version="1.0" encoding="UTF-8"?>
<DPS versao="1.00" xmlns="http://www.sped.fazenda.gov.br/nfse">
	<infDPS Id="{@IdDPS}">
		<tpAmb>{@tpAmb}</tpAmb>
		<dhEmi>{@dhEmi}</dhEmi>
		<verAplic>{@verAplic}</verAplic>
		<serie>{@serie}</serie>
		<nDPS>{@nDPS}</nDPS>
		<dCompet>{@dCompet}</dCompet>
		<tpEmit>{@tpEmit}</tpEmit>
		<!-- {@ifCMotivoEmisTI}
		<cMotivoEmisTI>{@cMotivoEmisTI}</cMotivoEmisTI>
		{@endifCMotivoEmisTI} -->
		<!-- {@ifChNFSeRej}
		<chNFSeRej>{@chNFSeRej}</chNFSeRej>
		{@endifChNFSeRej} -->
		<cLocEmi>{@cLocEmi}</cLocEmi>
		{@ifSubst}
