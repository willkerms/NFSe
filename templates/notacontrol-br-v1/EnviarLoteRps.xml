<?xml version="1.0" encoding="utf-8"?>
<EnviarLoteRpsEnvio xmlns="http://www.sped.fazenda.gov.br/nfse" xmlns:ns2="http://www.w3.org/2000/09/xmldsig#">
	<LoteRps id="lt{@idRps}">
		<tc:NumeroLote>{@NumeroLote}</tc:NumeroLote>
		<tc:Prestador>
			<!-- FAZER IF CNPJ/CPF tc:-->
			{@ifCNPJPrestador}
			<tc:CNPJ>{@CNPJPrestador}</tc:CNPJ>
			{@endifCNPJPrestador}

			{@ifCPFPrestador}
			<tc:CPF>{@CPFPrestador}</tc:CPF>
			{@endifCPFPrestador}
			
			<tc:IM>{@IMPrestador}</tc:IM>
		</tc:Prestador>
		<tc:QuantidadeDps>{@QuantidadeDps}</tc:QuantidadeDps>
		<tc:ListaDps>
			{@ListaDps}
		</tc:ListaDps>
	</LoteDps>
	<!--Signature></Signature-->
</EnviarLoteDpsEnvio>