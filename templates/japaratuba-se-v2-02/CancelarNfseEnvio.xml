<?xml version="1.0" encoding="UTF-8"?>
<CancelarNfseEnvio xmlns="http://www.abrasf.org.br/nfse.xsd" xmlns:ds="http://www.w3.org/2000/09/xmldsig#" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.abrasf.org.br/nfse.xsd">
	<Pedido>
		<InfPedidoCancelamento Id="cancelamento-{@Numero}">
			<IdentificacaoNfse>
				<Numero>{@Numero}</Numero>
				<CpfCnpj>
					{@ifCnpj}
					<Cnpj>{@Cnpj}</Cnpj>
					{@endifCnpj}
					{@ifCpf}
					<Cpf>{@Cpf}</Cpf>
					{@endifCpf}
				</CpfCnpj>
				
				{@ifInscricaoMunicipal}
				<InscricaoMunicipal>{@InscricaoMunicipal}</InscricaoMunicipal>
				{@endifInscricaoMunicipal}
				
				<CodigoMunicipio>{@CodigoMunicipio}</CodigoMunicipio>
			</IdentificacaoNfse>
			
			{@ifCodigoCancelamento}
			<CodigoCancelamento>{@CodigoCancelamento}</CodigoCancelamento>
			{@endifCodigoCancelamento}
		</InfPedidoCancelamento>
		<!--Signature>string</Signature-->
	</Pedido>
</CancelarNfseEnvio>