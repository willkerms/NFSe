<?xml version="1.0" encoding="utf-8"?>
<EnviarLoteRpsSincronoEnvio xmlns="http://shad.elotech.com.br/schemas/iss/nfse_v2_03.xsd">
	<IdentificacaoRequerente>
		<CpfCnpj>
			{@ifCpfPrestador}
			<Cpf>{@CpfPrestador}</Cpf>
			{@endifCpfPrestador}
			{@ifCnpjPrestador}
			<Cnpj>{@CnpjPrestador}</Cnpj>
			{@endifCnpjPrestador}
		</CpfCnpj>
		<InscricaoMunicipal>{@InscricaoMunicipalPrestador}</InscricaoMunicipal>
		<Senha>{@Senha}</Senha>
		<Homologa>{@Homologa}</Homologa>
	</IdentificacaoRequerente>

	<!-- 2. Lote contendo a Lista de RPS -->
	<LoteRps Id="lote-{@idLote}" versao="2.03" >
		<NumeroLote>{@NumeroLote}</NumeroLote>
		<CpfCnpj>
			{@ifCpfPrestador}
			<Cpf>{@CpfPrestador}</Cpf>
			{@endifCpfPrestador}
			{@ifCnpjPrestador}
			<Cnpj>{@CnpjPrestador}</Cnpj>
			{@endifCnpjPrestador}
		</CpfCnpj>
		<InscricaoMunicipal>{@InscricaoMunicipalPrestador}</InscricaoMunicipal>
		<QuantidadeRps>{@QuantidadeRps}</QuantidadeRps>
		<ListaRps>
			{@ListaRps}
		</ListaRps>
	</LoteRps>

</EnviarLoteRpsSincronoEnvio>
